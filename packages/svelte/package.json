{
  "name": "@anil-labs/dnd-svelte",
  "version": "0.1.0",
  "description": "Svelte bindings for @anil-labs/dnd-core — the use:draggable action for sortable lists, cross-list groups, multi-drag and keyboard a11y.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"covered by @anil-labs/dnd-core\"",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "keywords": [
    "svelte",
    "drag-and-drop",
    "dnd",
    "sortable",
    "draggable",
    "list",
    "reorder"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Er. Anil Kumar Thakur <anilkumarthakur60@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anilkumarthakur60/vue-dnd.git",
    "directory": "packages/svelte"
  },
  "homepage": "https://github.com/anilkumarthakur60/vue-dnd/tree/main/packages/svelte#readme",
  "bugs": "https://github.com/anilkumarthakur60/vue-dnd/issues",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anil-labs/dnd-core": "workspace:^"
  },
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "svelte": "^5.15.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
