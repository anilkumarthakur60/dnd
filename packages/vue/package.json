{
  "name": "@anil-labs/dnd",
  "version": "0.1.0",
  "description": "Vue 3 bindings for @anil-labs/dnd-core — the <Draggable> component and useDraggable composable for sortable lists, cross-list groups, multi-drag and keyboard a11y.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vue",
    "vue3",
    "drag-and-drop",
    "dnd",
    "sortable",
    "draggable",
    "list",
    "reorder"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Er. Anil Kumar Thakur <anilkumarthakur60@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anilkumarthakur60/vue-dnd.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/anilkumarthakur60/vue-dnd/tree/main/packages/vue#readme",
  "bugs": "https://github.com/anilkumarthakur60/vue-dnd/issues",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anil-labs/dnd-core": "workspace:^"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^25.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "vue": "^3.5.13"
  }
}
